# Experiment outputs (kept out of git; .gitkeep preserves the dir)
results/**/*.csv
results/**/*.png
!results/**/.gitkeep
# T40 canonical comparative artifacts are tracked (wiki/concepts/output-format).
!results/baseline/
!results/baseline/*.csv
# T46 Family B (delay) comparative dataset is tracked — the T48/T50 input.
!results/delay/
!results/delay/*.csv
# T46.1 sweep checkpoint sidecars (per-cell .json) are runtime-only — never
# tracked. Placed after the delay re-include so it wins for results/delay/.
results/**/.sweep/

