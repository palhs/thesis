__pycache__/
*.pyc
.venv/
.env

# Test + coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.egg-info/

# Experiment outputs (kept out of git; .gitkeep preserves the dir)
results/**/*.csv
results/**/*.png
!results/**/.gitkeep
# T40 canonical comparative artifacts are tracked (wiki/concepts/output-format).
!results/baseline/
!results/baseline/*.csv
# T46 Family B (delay) comparative dataset is tracked — the T48/T50 input.
!results/delay/
!results/delay/*.csv
# T51 Family C (delayed-voters) adversarial dataset is tracked — the T56 input.
!results/adversary/
!results/adversary/*.csv
# L-W10 H2(b) FFG slot-duration sensitivity sweep is tracked — the ch4 §4.2.2 input.
!results/sensitivity/
!results/sensitivity/*.csv
# T46.1 sweep checkpoint sidecars (per-cell .json) are runtime-only — never
# tracked. Placed after the delay re-include so it wins for results/delay/.
results/**/.sweep/
# T47 heavy-sweep checkpoint sidecars (same rationale).
results/**/.sweep_heavy/
# T51 Family C sweep checkpoint sidecars (same rationale).
results/**/.sweep_adversary/
# T52 offline-validators sweep checkpoint sidecars (same rationale).
results/**/.sweep_offline/
# T53 equivocating-nodes sweep checkpoint sidecars (same rationale).
results/**/.sweep_equivocate/
# Sweep stderr progress/timing logs (e.g. heavy_pass*.err) — runtime-only
# diagnostics with wall-clock timings; the durable record is the experiment
# page + the CSV commit_hash provenance.
results/**/*.err

# Claude Code harness runtime artifacts (session-local; not project state).
.claude/preview/
.claude/worktrees/
.claude/scheduled_tasks.lock

# OS
.DS_Store
Thumbs.db

# Obsidian
.obsidian
